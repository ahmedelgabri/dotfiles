{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"env": {
		"BASH_DEFAULT_TIMEOUT_MS": "120000",
		"CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
		"CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
		"CLAUDE_CODE_EFFORT_LEVEL": "high",
		"CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "64000",
		"CLAUDE_CODE_HIDE_ACCOUNT_INFO": "1",
		"CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
		"DISABLE_ERROR_REPORTING": "1",
		"DISABLE_TELEMETRY": "1",
		"USE_BUILTIN_RIPGREP": "0"
	},
	"alwaysThinkingEnabled": true,
	"includeCoAuthoredBy": false,
	"cleanupPeriodDays": 99999,
	"model": "opus[1m]",
	"permissions": {
		"allow": [
			"Bash(fd:*)",
			"Bash(rg:*)",
			"Bash(find:*)",
			"Bash(grep:*)",
			"Bash(cat:*)",
			"Bash(bat:*)",
			"Bash(yarn:*)",
			"Bash(pnpm:*)",
			"Bash(mkdir:*)",
			"Bash(echo:*)",
			"Bash(tail:*)",
			"Bash(head:*)",
			"Bash(cd:*)",
			"Bash(uniq:*)",
			"Bash(sort:*)",
			"Bash(awk:*)",
			"Bash(pwd:*)",
			"Bash(nix flake check:*)",
			"Bash(nix flake show:*)",
			"Bash(nix fmt:*)",
			"Bash(command git:*)",
			"Bash(git:*)",
			"Bash(gh pr view:*)",
			"Bash(gh issue view:*)",
			"Bash(gh repo view:*)",
			"Bash(gh run view:*)",
			"Bash(gh run list:*)",
			"Bash(jj diff:*)",
			"Bash(jj evolog:*)",
			"Bash(jj gr:*)",
			"Bash(jj last:*)",
			"Bash(jj log:*)",
			"Bash(jj o:*)",
			"Bash(jj oo:*)",
			"Bash(jj op log:*)",
			"Bash(jj st:*)",
			"Bash(jj status:*)",
			"Bash(jj show:*)",
			"Skill(commit)",
			"Skill(jujutsu)",
			"Bash(ast-grep:*)",
			"Bash(grit:*)",
			"Bash(make:*)",
			"WebSearch",
			"Read(~/.claude/host/*.md)",
			"Bash(jq:*)"
		],
		"deny": [
			"Glob",
			"Grep",
			"Read(.bashrc)",
			"Read(.env)",
			"Read(.env.*)",
			"Read(.envrc)",
			"Read(.git)",
			"Read(.profile)",
			"Read(.zshenv)",
			"Read(.zshrc)",
			"Read(.zsh_history)",
			"Read(node_modules)",
			"Write(.bashrc)",
			"Write(.env)",
			"Write(.env.*)",
			"Write(.envrc)",
			"Write(.profile)",
			"Write(.zshenv)",
			"Write(.zshrc)",
			"Write(.zsh_history)"
		],
		"ask": [
			"Bash(cp:*)",
			"Bash(curl:*)",
			"Bash(mv:*)",
			"Bash(node:*)",
			"Bash(rm:*)",
			"Bash(ssh:*)",
			"Bash(su:*)",
			"Bash(sudo:*)",
			"Bash(wget:*)",
			"Bash(xargs:*)",
			"Bash(gh repo delete *)",
			"Bash(gh secret delete *)",
			"Bash(gh secret set *)",
			"Bash(git branch:*)",
			"Bash(git checkout:*)",
			"Bash(git clean:*)",
			"Bash(git filter-branch:*)",
			"Bash(git gc:*)",
			"Bash(git prune:*)",
			"Bash(git push:*)",
			"Bash(git rebase:*)",
			"Bash(git reflog:*)",
			"Bash(git reset:*)",
			"Bash(git restore:*)",
			"Bash(command git branch:*)",
			"Bash(command git checkout:*)",
			"Bash(command git clean:*)",
			"Bash(command git filter-branch:*)",
			"Bash(command git gc:*)",
			"Bash(command git prune:*)",
			"Bash(command git push:*)",
			"Bash(command git rebase:*)",
			"Bash(command git reflog:*)",
			"Bash(command git reset:*)",
			"Bash(command git restore:*)"
		]
	},
	"enabledPlugins": {
		"claude-md-management@claude-plugins-official": true,
		"feature-dev@claude-plugins-official": true,
		"hookify@claude-plugins-official": true,
		"skill-creator@claude-plugins-official": true,
		"frontend-design@claude-plugins-official": true,
		"qmd@qmd": true
	},
	"extraKnownMarketplaces": {
		"qmd": {
			"source": {
				"source": "github",
				"repo": "tobi/qmd"
			}
		}
	},
	"statusLine": {
		"type": "command",
		"command": "~/.claude/scripts/statusline.sh"
	},
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/log-event.sh SessionStart"
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/log-event.sh SessionEnd"
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/log-event.sh UserPromptSubmit"
					},
					{
						"type": "command",
						"command": "~/.claude/hooks/aggregate-prompt.sh UserPromptSubmit"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/log-event.sh PreToolUse"
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/validate-bash.sh"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/log-event.sh PostToolUse"
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/log-event.sh Stop"
					},
					{
						"type": "command",
						"command": "ccpeek --index-only >> ~/Library/Logs/ccpeek-stdout.log 2>> ~/Library/Logs/ccpeek-stderr.log &"
					}
				]
			}
		],
		"SubagentStop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/log-event.sh SubagentStop"
					}
				]
			}
		],
		"Notification": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/log-event.sh Notification"
					},
					{
						"type": "command",
						"command": "jq -r '.message' | terminal-notifier -title Claude -subtitle \"Notification hook\" -activate com.mitchellh.ghostty"
					}
				]
			}
		],
		"PreCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "~/.claude/hooks/log-event.sh PreCompact"
					}
				]
			}
		]
	}
}
