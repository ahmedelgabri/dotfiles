#!/usr/bin/env bash

# Intentionally not setting -e because we want the script to continue if getting the location data fails
set -u -o pipefail

if [[ -n "${DEBUG-}" ]]; then
	set -x
fi

LOCATION_DATA="$TMPDIR/.location.json"
LOCATION_ICON="$(printf '\U000F0A77')"

# When location data is available use Mawaqit (mosque-specific times),
# otherwise fall back to Aladhan (city-level calculation).
if jq -e . "$LOCATION_DATA" >/dev/null 2>&1; then
	latitude="$(jq -r '.location.latitude' "$LOCATION_DATA")"
	longitude="$(jq -r '.location.longitude' "$LOCATION_DATA")"
	city="$(jq -r '.locality' "$LOCATION_DATA")"
	country="$(jq -r '.countryCode' "$LOCATION_DATA")"

	printf "%s" "$LOCATION_ICON $(next-prayer mawaqit \
		-latitude "$latitude" -longitude "$longitude" \
		-city "$city" -country "$country")"
else
	printf "%s" "$(next-prayer aladhan)"
fi
